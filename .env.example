# ============================================
# CircularOS Environment Configuration
# ============================================
# Copy this file to .env and fill in values
# Never commit .env to version control
# ============================================

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://circularos:circularos_dev@localhost:5433/circularos
DATABASE_SYNC_URL=postgresql://circularos:circularos_dev@localhost:5433/circularos
POSTGRES_USER=circularos
POSTGRES_PASSWORD=circularos_dev
POSTGRES_DB=circularos

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── Authentication ───────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=CHANGE_ME_TO_A_32_BYTE_KEY_BASE64

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── LLM Providers ───────────────────────────
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Model Routing ───────────────────────────
FAST_MODEL_PROVIDER=gemini
FAST_MODEL_NAME=gemini-2.5-flash

REASONING_MODEL_PROVIDER=openai
REASONING_MODEL_NAME=gpt-4o

CRITIC_MODEL_PROVIDER=anthropic
CRITIC_MODEL_NAME=claude-sonnet-4-20250514

# ── Embedding ────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Reranker ─────────────────────────────────
RERANKER_PROVIDER=
RERANKER_MODEL=

# ── Observability ────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=circularos

LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Knowledge Graph ──────────────────────────
# Using PostgreSQL relational tables by default
# Neo4j support available via graph repository abstraction
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ── External Sources ────────────────────────
SEBI_SOURCE_BASE_URL=https://www.sebi.gov.in

# ── Application ──────────────────────────────
APP_NAME=CircularOS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
WORKER_CONCURRENCY=4

# ── File Storage ─────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
